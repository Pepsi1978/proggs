# EditorConfig - Einheitliche Formatierung auf allen Systemen und Editoren
# https://editorconfig.org

root = true

# Standard fuer alle Dateien
[*]
charset = utf-8
indent_style = space
indent_size = 2
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true

# JavaScript (Tampermonkey-Skripte)
[*.js]
indent_size = 2
end_of_line = lf

# C# (Windows-Projekte)
[*.cs]
indent_size = 4
end_of_line = crlf

# XAML (WPF-Layouts)
[*.xaml]
indent_size = 4
end_of_line = crlf

# Swift (macOS-Projekte)
[*.swift]
indent_size = 4
end_of_line = lf

# PowerShell
[*.ps1]
indent_size = 4
end_of_line = crlf

# Shell-Skripte
[*.sh]
indent_size = 2
end_of_line = lf

# JSON
[*.json]
indent_size = 2
end_of_line = lf

# Markdown
[*.md]
trim_trailing_whitespace = false
