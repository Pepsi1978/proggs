{
	"description": "Claude Code Setup-Manifest - Installiert alle Plugins, Skills, Dev-Tools, MCP-Server und Settings auf einem neuen Rechner",
	"version": "3.0.0",
	"author": "Pepsi1978",
	"github_user": "Pepsi1978",
	"repo": "https://github.com/Pepsi1978/proggs",

	"dev_tools": {
		"required": ["node", "git", "gh"],
		"recommended": {
			"bun": {
				"macos": "brew install oven-sh/bun/bun",
				"windows": "winget install Oven-sh.Bun"
			},
			"deno": {
				"macos": "brew install deno",
				"windows": "winget install DenoLand.Deno"
			},
			"rust": {
				"macos": "curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y",
				"windows": "winget install Rustlang.Rustup"
			},
			"go": {
				"macos": "brew install go",
				"windows": "winget install GoLang.Go"
			},
			"dotnet": {
				"macos": "brew install dotnet-sdk",
				"windows": "winget install Microsoft.DotNet.SDK.10"
			},
			"java": {
				"macos": "brew install openjdk",
				"windows": "winget install Microsoft.OpenJDK.21"
			},
			"cmake": {
				"macos": "brew install cmake",
				"windows": "winget install Kitware.CMake"
			},
			"llvm": {
				"macos": "brew install llvm",
				"windows": "winget install LLVM.LLVM"
			},
			"make": {
				"macos": "already included with Xcode CLI tools",
				"windows": "winget install GnuWin32.Make"
			},
			"jq": {
				"macos": "brew install jq",
				"windows": "winget install jqlang.jq"
			},
			"uv": {
				"macos": "curl -LsSf https://astral.sh/uv/install.sh | sh",
				"windows": "winget install astral-sh.uv"
			}
		}
	},

