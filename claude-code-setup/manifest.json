	"mcp_servers": {
		"_comment_paths": "Use absolute paths for commands on macOS (e.g. /opt/homebrew/bin/npx) and Windows (e.g. C:\\Users\\...\\AppData\\Roaming\\npm\\npx.cmd) — never bare command names",
		"sequential-thinking": {
			"command": "npx",
			"args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
			"_note": "Replace 'npx' with absolute path: macOS=/opt/homebrew/bin/npx, Windows=C:\\Users\\barwa\\AppData\\Roaming\\npm\\npx.cmd"
		}
	},

	"security_tools": {
		"parry": {
			"install": {
				"macos": "cargo install --git https://github.com/vaporif/parry-guard parry-guard --no-default-features --features candle",
				"windows": "not supported (use macOS or WSL)"
			},
			"hooks": {
				"PreToolUse": { "command": "parry-guard hook", "timeout": 1000 },
				"PostToolUse": { "command": "parry-guard hook", "timeout": 5000 },
				"UserPromptSubmit": { "command": "parry-guard hook", "timeout": 2000 }
			},
			"note": "Requires HuggingFace token (HF_TOKEN). Full mode needs --features candle."
		},
		"lasso-defender": {
			"install": "pip install pyyaml (or uv available)",
			"hooks": {
				"PostToolUse": {
					"matcher": "Read|WebFetch|Bash|Grep|Task",
					"command": "uv run $HOME/.claude/hooks/prompt-injection-defender/post-tool-defender.py",
					"timeout": 5
				}
			},
			"description": "Pattern-based prompt injection scanner (50+ patterns, 4 categories)"
		},
		"cargo-audit": {
			"install": {
				"macos": "cargo install cargo-audit",
				"windows": "cargo install cargo-audit"
			},
			"description": "Scans Rust crate dependencies for known CVEs (run: cargo audit)"
		}
	},

