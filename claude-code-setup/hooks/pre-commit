#!/bin/bash
# Gitleaks Pre-Commit Hook — blocks commits containing secrets/API keys
# Scans only staged changes (not entire history)

if ! command -v gitleaks &> /dev/null; then
    echo "⚠️  gitleaks not installed — skipping secret scan"
    exit 0
fi

gitleaks git --pre-commit --staged --no-banner 2>&1
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "🚨 SECRETS DETECTED — Commit blocked!"
    echo ""
    echo "   gitleaks found potential secrets in your staged files."
    echo "   Review the findings above and remove any real secrets."
    echo ""
    echo "   If this is a false positive, commit with:"
    echo "   git commit --no-verify"
    echo ""
    exit 1
fi

exit 0
