      }
    },
    "_comment_boostvolt": "Removed: boostvolt/claude-code-lsps plugin not found (2026-03-28)",
    "trailofbits/skills-curated": {
      "source": {
        "source": "github",
        "repo": "trailofbits/skills-curated"
      }
    },
    "_comment_FlineDev": "Removed: FlineDev/context-kit repo cannot be cloned (2026-03-28)"
  },
  "language": "de",
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "_comment_PermissionRequest": "Intentionally removed — caused bypassPermissions mode reset (2026-03-20)",
  "mcpServers": {
    "android-adb": {
      "type": "stdio",
      "command": "/opt/homebrew/bin/npx",
      "args": [
        "-y",
        "android-debug-bridge-mcp"
      ]
    }
  }
