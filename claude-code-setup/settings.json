    "ddd@context-engineering-kit": true,
    "sdd@context-engineering-kit": true,
    "kaizen@context-engineering-kit": true,
    "customaize-agent@context-engineering-kit": true,
    "docs@context-engineering-kit": true,
    "tech-stack@context-engineering-kit": true,
    "mcp@context-engineering-kit": true,
    "fpf@context-engineering-kit": true,
    "xclaude-plugin@xclaude-plugin-marketplace": true,
    "apple-platform-build-tools@apple-platform-build-tools": true,
    "claude-reflect@claude-reflect-marketplace": true
  },
  "extraKnownMarketplaces": {
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      },
      "autoUpdate": true
    },
    "trailofbits": {
      "source": {
        "source": "github",
        "repo": "trailofbits/skills"
      }
    },
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    },
    "everything-claude-code": {
      "source": {
        "source": "github",
        "repo": "affaan-m/everything-claude-code"
      }
    },
    "compound-engineering-plugin": {
      "source": {
        "source": "github",
        "repo": "EveryInc/compound-engineering-plugin"
      }
    },
    "context-engineering-kit": {
