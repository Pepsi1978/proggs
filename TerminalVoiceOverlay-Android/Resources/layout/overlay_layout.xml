<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="72dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@drawable/pill_background"
    android:paddingTop="16dp"
    android:paddingBottom="16dp"
    android:paddingLeft="10dp"
    android:paddingRight="10dp"
    android:elevation="8dp">

    <!-- X Button (clear) — red circle -->
    <FrameLayout
        android:id="@+id/btn_x"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/circle_button"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="X"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- W Button (whisper undo) — green circle -->
    <FrameLayout
        android:id="@+id/btn_w"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/circle_button"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="W"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- BTW Mic Button — light blue rounded square -->
    <FrameLayout
        android:id="@+id/btn_btw"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/mic_button"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="&#127908;"
            android:textSize="22sp" />
    </FrameLayout>

    <!-- Main Mic Button — dark blue rounded square -->
    <FrameLayout
        android:id="@+id/btn_mic"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/mic_button"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="&#127908;"
            android:textSize="22sp" />
    </FrameLayout>

    <!-- G Button (Gemini toggle) — dark circle -->
    <FrameLayout
        android:id="@+id/btn_g"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/circle_button"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="G"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- Enter Button (auto-enter toggle) — orange circle -->
    <FrameLayout
        android:id="@+id/btn_enter"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/circle_button"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="&#9166;"
            android:textColor="@android:color/white"
            android:textSize="18sp" />
    </FrameLayout>

</LinearLayout>
