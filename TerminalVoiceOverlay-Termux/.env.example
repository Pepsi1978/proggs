# Groq API Key (erforderlich) — https://console.groq.com/
GROQ_API_KEY=gsk_xxxxxxxxxxxxx

# Whisper-Modell (optional, Standard: whisper-large-v3)
WHISPER_MODEL=whisper-large-v3

# Sprache der Aufnahme (optional, Standard: de)
WHISPER_LANG=de

# Gemini API Key (optional) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gemini-Modell (optional, Standard: gemini-3.1-flash-lite-preview)
GEMINI_MODEL=gemini-3.1-flash-lite-preview
